# Copy to .env.local and fill in. Required for the contact / demo forms.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Default inbox that receives form submissions (fallback for the two below)
CONTACT_EMAIL=you@example.com

# Optional split routing: demo requests -> SALES_EMAIL, contact messages -> SUPPORT_EMAIL.
# If unset, both fall back to CONTACT_EMAIL.
SALES_EMAIL=sales@example.com
SUPPORT_EMAIL=support@example.com

# Sender shown on the email. For production, use an address on a domain you've
# verified in Resend (e.g. "BuildAlly <hello@buildally.in>"). The default below
# is Resend's test sender, which can only deliver to your own Resend account email.
RESEND_FROM_EMAIL="BuildAlly <onboarding@resend.dev>"
